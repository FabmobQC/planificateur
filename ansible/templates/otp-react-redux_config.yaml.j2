#     rect:
#       minLon: -123.2034
#       maxLon: -122.135
#       minLat: 45.273
#       maxLat: 45.7445
#   focusPoint:
#     lat: 45.5223452
#     lon: -122.6821804
#   # required geocoder type.
#   type: ARCGIS

# Use this mode config for the enhanced Transit+ config
modes:
  # Definition for the mode buttons to display in trip form
  modeButtons:
    - iconName: bus
      key: transit
      label: Transit
      # List of modes to add to the query when this button is enabled
      modes:
        - mode: TRANSIT
        - mode: FLEX
          qualifier: DIRECT
    - iconName: bicycle
      key: bicycle
      label: Bicycle
      modes:
        # Modes can contain a qualifier
        # See OTP documentation for details
        - mode: BICYCLE
#       - mode: BICYCLE
#         qualifier: RENT
    - iconName: taxi
      key: taxi
      label: Taxi
      modes:
        - mode: TAXI
    - iconName: car
      key: car
      label: Car
      modes:
        - mode: CAR
  # Allows initial state to be configured.
  # Which buttons enabled on load + overriding setting defaults
  initialState:
    enabledModeButtons: # Mode button keys enabled by default
      - transit
      - bicycle
      - taxi
      - car
  # Add additional mode settings to show up in mode selector hover panel
  modeSettingDefinitions:
    # Corresponding mode; if this mode is found in the button's mode list,
    # this setting will show up in the hover panel for that button.
    - applicableMode: TAXI
      default: true # Initial state value
      # One of the predefined query parameter names.
      # See OTP-UI ModeSelector component for a list of supported parameter names.
      key: taxiStandard
#     iconName: wheelchair
      type: CHECKBOX # Possible options: CHECKBOX, SUBMODE, SLIDER, DROPDOWN
    - applicableMode: TAXI
      default: false
      key: taxiMinivan
      type: CHECKBOX
    - applicableMode: TAXI
      key: taxiSpecial
      type: CHECKBOX
    - applicableMode: CAR
      key: vehiculeType
      type: DROPDOWN
      options:
        - value: small
        - value: medium
        - value: large
        - value: vus
        - value: sport
      default: medium
    - applicableMode: CAR
      key: nbKmPerYear
      type: DROPDOWN
      options:
        - value: 10000
        - value: 15000
        - value: 20000
        - value: 30000
      default: 10000
    - applicableMode: CAR
      key: paidParkingTime
      type: DROPDOWN
      options:
        - value: 0
        - value: 0.25
        - value: 0.5
        - value: 0.75
        - value: 1
        - value: 2
        - value: 3
        - value: 4
      default: 0.25
  transitModes:
    - mode: BUS
      label: Bus
      # A mode color can be added, used throughout the application,
      # most notably in the enhanced stop viewer bubble
      color: blue
    - mode: SUBWAY
      label: Metro

  # Potentially deprecated
# accessModes:
#   - mode: BICYCLE
#     label: Transit + Bike

